<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <form class="d-flex gap-2 mb-3"><input class="form-control" name="search"
                                    value="<%= search %>" placeholder="Buscar paciente o documento"><button
                                    class="btn btn-primary">Buscar</button></form>
                            <div class="card border-0 shadow-sm rounded-4">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Documento</th>
                                            <th>Paciente</th>
                                            <th>Género</th>
                                            <th>Órdenes LIS</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% pacientes.forEach(p=>{ %><tr>
                                                <td>
                                                    <%= p.tipo_documento %>
                                                        <%= p.numero_documento %>
                                                </td>
                                                <td>
                                                    <%= p.primer_nombre %>
                                                        <%= p.segundo_nombre || '' %>
                                                            <%= p.primer_apellido %>
                                                                <%= p.segundo_apellido || '' %>
                                                </td>
                                                <td>
                                                    <%= p.genero %>
                                                </td>
                                                <td>
                                                    <%= p.ordenes %>
                                                </td>
                                                <td class="text-end"><a class="btn btn-sm btn-primary"
                                                        href="/pacientes/<%= p.id %>/historial">Historial LIS</a></td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>