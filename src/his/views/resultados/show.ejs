<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4 class="fw-bold">Resultado <%= resultado.sistema_origen %>
                                            </h4>
                                            <p class="text-muted mb-0">Orden <%= resultado.numero_orden %> · Paciente
                                                    <%= resultado.paciente %> · <%= resultado.numero_documento %>
                                            </p>
                                        </div><a href="/resultados" class="btn btn-light border">Volver</a>
                                    </div>
                                    <hr>
                                    <div class="row g-3">
                                        <div class="col-md-4"><strong>Tipo</strong>
                                            <p>
                                                <%= resultado.tipo_resultado %>
                                            </p>
                                        </div>
                                        <div class="col-md-4"><strong>Validado por</strong>
                                            <p>
                                                <%= resultado.validado_por || 'No registra' %>
                                            </p>
                                        </div>
                                        <div class="col-md-4"><strong>Fecha validación</strong>
                                            <p>
                                                <%= resultado.fecha_validacion ? new
                                                    Date(resultado.fecha_validacion).toLocaleString('es-CO')
                                                    : 'No registra' %>
                                            </p>
                                        </div>
                                        <div class="col-12"><strong>Resumen</strong>
                                            <p>
                                                <%= resultado.resumen || 'Sin resumen' %>
                                            </p>
                                        </div>
                                    </div>
                                    <% const data=resultado.resultado_json || {}; %>
                                        <% if(resultado.sistema_origen==='LIS' && data.resultados){ %>
                                            <h5 class="mt-4">Pruebas de laboratorio</h5>
                                            <div class="table-responsive">
                                                <table class="table table-bordered">
                                                    <thead>
                                                        <tr>
                                                            <th>CUPS</th>
                                                            <th>Prueba</th>
                                                            <th>Resultado</th>
                                                            <th>Unidad</th>
                                                            <th>Referencia</th>
                                                            <th>Crítico</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% data.resultados.forEach(x=>{ %><tr>
                                                                <td>
                                                                    <%= x.codigo_cups %>
                                                                </td>
                                                                <td>
                                                                    <%= x.prueba %>
                                                                </td>
                                                                <td>
                                                                    <%= x.resultado %>
                                                                </td>
                                                                <td>
                                                                    <%= x.unidad || '' %>
                                                                </td>
                                                                <td>
                                                                    <%= x.valor_referencia || '' %>
                                                                </td>
                                                                <td>
                                                                    <%= x.es_critico || x.critico ? 'Sí' :'No' %>
                                                                </td>
                                                            </tr>
                                                            <% }) %>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <% } %>
                                                <% if(resultado.sistema_origen==='RIS' && data.informe){ %>
                                                    <h5 class="mt-4">Informe radiológico</h5>
                                                    <div class="row g-3">
                                                        <div class="col-12"><strong>Pregunta clínica</strong>
                                                            <p>
                                                                <%= data.informe.pregunta_clinica || 'No registra' %>
                                                            </p>
                                                        </div>
                                                        <div class="col-12"><strong>Técnica usada</strong>
                                                            <p>
                                                                <%= data.informe.tecnica_usada || 'No registra' %>
                                                            </p>
                                                        </div>
                                                        <div class="col-12"><strong>Hallazgos</strong>
                                                            <p>
                                                                <%= data.informe.hallazgos %>
                                                            </p>
                                                        </div>
                                                        <div class="col-12"><strong>Conclusión</strong>
                                                            <p>
                                                                <%= data.informe.conclusion %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    <% if(data.orthanc && data.orthanc.url_visualizacion){ %><a
                                                            class="btn btn-dark" target="_blank"
                                                            href="<%= data.orthanc.url_visualizacion %>">Abrir imágenes
                                                            Orthanc</a>
                                                        <% } %>
                                                            <% } %>
                                </div>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>