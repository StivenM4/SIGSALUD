<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Orden</th>
                                            <th>Paciente</th>
                                            <th>Modalidad</th>
                                            <th>Estudio</th>
                                            <th>Estado</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% estudios.forEach(e=>{ %><tr>
                                                <td>
                                                    <%= e.numero_orden_his %>
                                                </td>
                                                <td>
                                                    <%= e.paciente %>
                                                </td>
                                                <td>
                                                    <%= e.modalidad||'' %>
                                                </td>
                                                <td>
                                                    <%= e.descripcion %>
                                                </td>
                                                <td>
                                                    <%= e.estado %>
                                                </td>
                                                <td><a href="/estudios/<%= e.id %>"
                                                        class="btn btn-sm btn-outline-primary">Ver</a></td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>