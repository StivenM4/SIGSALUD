<!doctype html><html lang="es"><%- include('../partials/head',{title}) %><body><div class="app-layout"><%- include('../partials/sidebar') %><main class="app-main"><%- include('../partials/navbar',{title}) %><section class="container-fluid py-4"><div class="card border-0 shadow-sm rounded-4"><div class="card-body p-4"><% if(error){ %><div class="alert alert-danger"><%= error %></div><% } %><form method="POST" action="/agenda" class="row g-3"><div class="col-md-6"><label class="form-label">Estudio</label><select name="estudio_id" class="form-select" required><% estudios.forEach(e=>{ %><option value="<%= e.id %>"><%= e.numero_orden_his %> - <%= e.paciente %> - <%= e.descripcion %></option><% }) %></select></div><div class="col-md-3"><label class="form-label">Sala</label><select name="sala_id" class="form-select"><% salas.forEach(s=>{ %><option value="<%= s.id %>"><%= s.nombre %></option><% }) %></select></div><div class="col-md-3"><label class="form-label">Fecha y hora</label><input type="datetime-local" name="fecha_hora" class="form-control" required></div><div class="col-12 text-end"><button class="btn btn-primary">Guardar agenda</button></div></form></div></div></section></main></div><%- include('../partials/scripts') %></body></html>
