<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Código muestra</th>
                                            <th>Orden</th>
                                            <th>Paciente</th>
                                            <th>Tipo</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% muestras.forEach(m=>{ %><tr>
                                                <td><strong>
                                                        <%= m.codigo_muestra %>
                                                    </strong></td>
                                                <td>
                                                    <%= m.numero_orden_his %>
                                                </td>
                                                <td>
                                                    <%= m.paciente %>
                                                </td>
                                                <td>
                                                    <%= m.tipo_muestra %>
                                                </td>
                                                <td>
                                                    <%= m.estado %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>