<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body">
                                    <h4>Orden <%= order.numero_orden_his %>
                                    </h4>
                                    <p class="text-muted">Paciente: <%= order.paciente %> · Documento: <%=
                                                order.numero_documento %>
                                    </p>
                                    <h6>Pruebas</h6>
                                    <ul>
                                        <% details.forEach(d=>{ %><li>
                                                <%= d.codigo_cups %> - <%= d.nombre %>
                                            </li>
                                            <% }) %>
                                    </ul>
                                    <form method="POST" action="/ordenes/<%= order.id %>/tomar-muestra"><button
                                            class="btn btn-success">Tomar muestra y generar código</button></form><a
                                        class="btn btn-primary mt-2" href="/resultados/<%= order.id %>">Registrar
                                        resultados</a>
                                </div>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>