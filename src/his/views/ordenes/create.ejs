<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body">
                                    <form method="GET" action="/ordenes/crear/tipo" class="row g-3 mb-4">
                                        <div class="col-md-8"><label class="form-label">Tipo de orden</label><select
                                                name="tipo_orden_id" class="form-select">
                                                <% tiposOrden.forEach(t=>{ %><option value="<%= t.id %>"
                                                        <%=selectedTipo&&selectedTipo.id===t.id?'selected':'' %>><%=
                                                            t.nombre %> - <%= t.sistema_destino %>
                                                    </option>
                                                    <% }) %>
                                            </select></div>
                                        <div class="col-md-4 d-flex align-items-end"><button
                                                class="btn btn-outline-primary w-100">Cargar procedimientos</button>
                                        </div>
                                    </form>
                                    <form method="POST" action="/ordenes" class="row g-3"><input type="hidden"
                                            name="tipo_orden_id" value="<%= selectedTipo?selectedTipo.id:'' %>">
                                        <div class="col-md-6"><label class="form-label">Paciente</label><select
                                                name="paciente_id" class="form-select">
                                                <% pacientes.forEach(p=>{ %><option value="<%= p.id %>">
                                                        <%= p.numero_documento %> - <%= p.nombre_completo %>
                                                    </option>
                                                    <% }) %>
                                            </select></div>
                                        <div class="col-md-3"><label class="form-label">Prioridad</label><select
                                                name="prioridad_id" class="form-select">
                                                <% prioridades.forEach(p=>{ %><option value="<%= p.id %>">
                                                        <%= p.nombre %>
                                                    </option>
                                                    <% }) %>
                                            </select></div>
                                        <div class="col-md-3"><label class="form-label">Destino</label><input
                                                class="form-control" disabled
                                                value="<%= selectedTipo?selectedTipo.sistema_destino:'Seleccione tipo' %>">
                                        </div>
                                        <div class="col-12"><label class="form-label">Procedimientos</label>
                                            <div class="procedure-box">
                                                <% procedimientos.forEach(proc=>{ %><label><input type="checkbox"
                                                            name="procedimientos" value="<%= proc.id %>">
                                                        <%= proc.codigo %> - <%= proc.nombre %>
                                                    </label>
                                                    <% }) %>
                                                        <% if(!procedimientos.length){ %><span
                                                                class="text-muted">Seleccione tipo para cargar
                                                                procedimientos.</span>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <div class="col-12"><label class="form-label">Observaciones</label><textarea
                                                name="observaciones" class="form-control"></textarea></div>
                                        <div class="col-12 text-end"><button class="btn btn-primary"
                                                <%=selectedTipo?'':'disabled' %>>Crear y enviar por API REST</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>