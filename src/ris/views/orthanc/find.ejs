<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body">
                                    <h4>Buscar en Orthanc /tools/find</h4>
                                    <% if(error){ %>
                                        <div class="alert alert-danger">
                                            <%= error %>
                                        </div>
                                        <% } %>
                                            <form method="POST" action="/orthanc/find" class="row g-3">
                                                <div class="col-md-3"><label class="form-label">Nivel</label><select
                                                        name="level" class="form-select">
                                                        <option>Study</option>
                                                        <option>Series</option>
                                                        <option>Instance</option>
                                                    </select></div>
                                                <div class="col-md-4"><label class="form-label">PatientID</label><input
                                                        name="patient_id" class="form-control" placeholder="*"></div>
                                                <div class="col-md-4"><label
                                                        class="form-label">Descripción</label><input name="description"
                                                        class="form-control" placeholder="*"></div>
                                                <div class="col-md-1 d-flex align-items-end"><button
                                                        class="btn btn-primary">Buscar</button></div>
                                            </form>
                                            <hr>
                                            <pre><%= results ? JSON.stringify(results,null,2) : 'Sin resultados' %></pre>
                                </div>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>