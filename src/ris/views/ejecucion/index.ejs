<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="alert alert-warning">Vista para tecnólogos: solo ejecución del estudio e
                                imágenes. La creación de informes queda separada para médicos/radiólogos.</div>
                            <div class="card border-0 shadow-sm rounded-4">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Estado</th>
                                            <th>Orden</th>
                                            <th>Paciente</th>
                                            <th>Estudio</th>
                                            <th>Modalidad</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% estudios.forEach(e=>{ %><tr>
                                                <td><span class="badge bg-dark">
                                                        <%= e.letra_estado %>
                                                    </span>
                                                    <%= e.estado %>
                                                </td>
                                                <td>
                                                    <%= e.numero_orden_his %>
                                                </td>
                                                <td>
                                                    <%= e.paciente %><br><small>
                                                            <%= e.numero_documento %>
                                                        </small>
                                                </td>
                                                <td>
                                                    <%= e.descripcion %>
                                                </td>
                                                <td>
                                                    <%= e.modalidad || '' %>
                                                </td>
                                                <td class="text-end"><a href="/estudios/<%= e.id %>"
                                                        class="btn btn-sm btn-outline-primary">Ver</a>
                                                    <form class="d-inline" method="POST"
                                                        action="/estudios/<%= e.id %>/ejecutar"><button
                                                            class="btn btn-sm btn-warning">Marcar ejecutado</button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>