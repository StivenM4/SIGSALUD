<!doctype html><html lang="es"><%- include('../partials/head',{title}) %><body><div class="app-layout"><%- include('../partials/sidebar') %><main class="app-main"><%- include('../partials/navbar',{title}) %><section class="container-fluid py-4"><div class="d-flex justify-content-between mb-3"><form class="d-flex gap-2"><input name="search" value="<%= search %>" class="form-control" placeholder="Buscar"><button class="btn btn-primary">Buscar</button></form><a class="btn btn-success" href="/pacientes/crear">Nuevo paciente</a></div><div class="card border-0 shadow-sm rounded-4"><table class="table table-hover mb-0"><thead><tr><th>Documento</th><th>Paciente</th><th>Nacimiento</th><th>Género</th><th>Teléfono</th><th></th></tr></thead><tbody><% pacientes.forEach(function(p){ %><tr><td><%= p.tipo_documento %> <%= p.numero_documento %></td><td><%= p.nombre_completo %></td><td><%= new Date(p.fecha_nacimiento).toLocaleDateString('es-CO') %></td><td><%= p.genero %></td><td><%= p.telefono||'' %></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" href="/pacientes/<%= p.id %>">Ver</a></td></tr><% }) %></tbody></table></div></section></main></div><%- include('../partials/scripts') %></body></html>
