<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <% if(error){ %>
                                <div class="alert alert-danger">
                                    <%= error %>
                                </div>
                                <% } %>
                                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                                        <div class="card-body">
                                            <h4 class="fw-bold">Validación LIS - Orden <%= order.numero_orden_his %>
                                            </h4>
                                            <p class="text-muted mb-0">Paciente: <%= order.paciente %> · Documento: <%=
                                                        order.numero_documento %> · Prioridad: <%= order.prioridad %>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="row g-4">
                                        <div class="col-lg-5">
                                            <div class="card border-0 shadow-sm rounded-4">
                                                <div class="card-header bg-white fw-bold">Muestras</div>
                                                <div class="card-body">
                                                    <% muestras.forEach(m=>{ %><div class="alert alert-light border">
                                                            <strong>
                                                                <%= m.codigo_muestra %>
                                                            </strong><br>Tipo: <%= m.tipo_muestra %><br>Estado: <%=
                                                                    m.estado %><br>Fecha: <%= new
                                                                        Date(m.created_at).toLocaleString('es-CO') %>
                                                        </div>
                                                        <% }) %>
                                                            <% if(!muestras.length){ %>
                                                                <p class="text-muted">No hay muestra tomada.</p>
                                                                <% } %>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-7">
                                            <div class="card border-0 shadow-sm rounded-4">
                                                <div class="card-header bg-white fw-bold">Resultados a validar</div>
                                                <div class="table-responsive">
                                                    <table class="table table-bordered mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>CUPS</th>
                                                                <th>Prueba</th>
                                                                <th>Resultado</th>
                                                                <th>Referencia</th>
                                                                <th>Crítico</th>
                                                                <th>Validado</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% resultados.forEach(r=>{ %><tr>
                                                                    <td>
                                                                        <%= r.codigo_cups %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.prueba %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.resultado %>
                                                                            <%= r.unidad || '' %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.valor_referencia || '' %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.es_critico?'Sí':'No' %>
                                                                    </td>
                                                                    <td>
                                                                        <%= r.validado?'Sí':'No' %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                                    <% if(!resultados.length){ %>
                                                                        <tr>
                                                                            <td colspan="6"
                                                                                class="text-center text-muted">No hay
                                                                                resultados registrados.</td>
                                                                        </tr>
                                                                        <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card border-0 shadow-sm rounded-4 mt-4">
                                        <div class="card-body d-flex justify-content-between align-items-center">
                                            <div><strong>Acción final</strong>
                                                <p class="text-muted mb-0">Al confirmar, el resultado se valida
                                                    electrónicamente y se envía al HIS para anexarlo a la historia
                                                    clínica.</p>
                                            </div>
                                            <form method="POST" action="/validaciones/<%= order.id %>/enviar-his">
                                                <button class="btn btn-success btn-lg">Validar y enviar al HIS</button>
                                            </form>
                                        </div>
                                    </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>