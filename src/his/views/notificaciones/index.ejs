<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Estado</th>
                                            <th>Título</th>
                                            <th>Paciente</th>
                                            <th>Orden</th>
                                            <th>Fecha</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% notificaciones.forEach(n=>{ %><tr>
                                                <td><span class="badge <%= n.leida?'bg-secondary':'bg-primary' %>">
                                                        <%= n.leida?'Leída':'Nueva' %>
                                                    </span></td>
                                                <td><strong>
                                                        <%= n.titulo %>
                                                    </strong><br><small>
                                                        <%= n.mensaje %>
                                                    </small></td>
                                                <td>
                                                    <%= n.paciente || '' %>
                                                </td>
                                                <td>
                                                    <%= n.numero_orden || '' %>
                                                </td>
                                                <td>
                                                    <%= new Date(n.created_at).toLocaleString('es-CO') %>
                                                </td>
                                                <td>
                                                    <% if(!n.leida){ %>
                                                        <form method="POST" action="/notificaciones/<%= n.id %>/leida">
                                                            <button class="btn btn-sm btn-outline-success">Marcar
                                                                leída</button></form>
                                                        <% } %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>