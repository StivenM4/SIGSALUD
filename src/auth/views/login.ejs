<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/login.css" rel="stylesheet">
</head>
<body>
  <main class="login-shell">
    <section class="brand-panel">
      <div class="brand-glass">
        <div class="brand-logo"><i class="bi bi-heart-pulse-fill"></i></div>
        <h1>SIGSALUD</h1>
        <p>Sistema Integrado de Información en Salud</p>
        <span>Acceso seguro a HIS, LIS y RIS</span>
      </div>
      <div class="server-state"><span class="pulse"></span>Servidor Auth: En línea</div>
    </section>
    <section class="login-panel">
      <div class="card login-card border-0 shadow-lg">
        <div class="card-body p-4 p-lg-5">
          <div class="text-center mb-4">
            <h2 class="fw-bold text-primary mb-1">Iniciar sesión</h2>
            <small class="text-muted">Seleccione un sistema e ingrese sus credenciales</small>
          </div>
          <% if (error) { %><div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success py-2"><i class="bi bi-check-circle-fill me-2"></i><%= success %></div><% } %>
          <form method="POST" action="/login" id="loginForm">
            <input type="hidden" name="system" id="systemInput" value="<%= selectedSystem %>">
            <div class="mb-3">
              <label class="form-label">Usuario o correo electrónico</label>
              <div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span><input type="email" class="form-control" name="email" placeholder="usuario@sigsalud.com" required></div>
            </div>
            <div class="mb-3">
              <label class="form-label">Contraseña</label>
              <div class="input-group"><span class="input-group-text"><i class="bi bi-lock"></i></span><input type="password" class="form-control" id="password" name="password" required><button class="btn btn-outline-secondary" type="button" id="togglePassword"><i class="bi bi-eye"></i></button></div>
            </div>
            <div class="module-separator my-4"><span>Seleccione el sistema</span></div>
            <div class="row g-3 module-grid">
              <% systems.forEach(function(system) { %>
                <div class="col-4">
                  <button type="button" class="module-card <%= selectedSystem === system.codigo ? 'active' : '' %>" data-system="<%= system.codigo %>">
                    <i class="bi <%= system.icono_bootstrap %> text-<%= system.color %>"></i>
                    <strong><%= system.codigo %></strong>
                    <small><%= system.nombre %></small>
                  </button>
                </div>
              <% }) %>
            </div>
            <button class="btn btn-primary w-100 py-2 fw-semibold mt-4" type="submit"><i class="bi bi-box-arrow-in-right me-2"></i>Ingresar</button>
            <button type="button" class="btn btn-light border w-100 mt-3" data-bs-toggle="collapse" data-bs-target="#demoUsers"><i class="bi bi-shield-lock me-2"></i>Usuarios de prueba</button>
            <div class="collapse mt-3" id="demoUsers">
              <div class="small bg-light rounded p-3 border">
                <p class="mb-2"><strong>Contraseña:</strong> Admin123*</p>
                <div class="row"><div class="col-md-6"><div>admin@sigsalud.com</div><div>medico@sigsalud.com</div><div>recepcion@sigsalud.com</div><div>medico.laboratorio@sigsalud.com</div><div>bacteriologo@sigsalud.com</div></div><div class="col-md-6"><div>laboratorio@sigsalud.com</div><div>medico.radiologia@sigsalud.com</div><div>radiologia@sigsalud.com</div><div>paciente@sigsalud.com</div></div></div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/login.js"></script>
</body>
</html>
