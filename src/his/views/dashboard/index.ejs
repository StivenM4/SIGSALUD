<!doctype html>
<html lang="es">
<%- include('../partials/head', { title }) %>

  <body>
    <div class="app-layout">
      <%- include('../partials/sidebar') %>

        <main class="app-main">
          <%- include('../partials/navbar', { title }) %>

            <section class="container-fluid py-4">
              <div class="row g-3 mb-4">
                <% const cards=[ ['Pacientes', stats.total_pacientes || 0, 'bi-people' ], ['Citas hoy', stats.citas_hoy
                  || 0, 'bi-calendar' ], ['Órdenes', stats.total_ordenes || 0, 'bi-clipboard2-pulse' ],
                  ['Notificaciones', stats.notificaciones || 0, 'bi-bell' ] ]; %>

                  <% cards.forEach(function(s) { %>
                    <div class="col-md-3">
                      <div class="card stat-card border-0 shadow-sm">
                        <div class="card-body">
                          <span>
                            <%= s[0] %>
                          </span>
                          <h3>
                            <%= s[1] %>
                          </h3>
                          <i class="bi <%= s[2] %>"></i>
                        </div>
                      </div>
                    </div>
                    <% }) %>
              </div>

              <div class="row g-4">
                <div class="col-lg-8">
                  <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white fw-bold">
                      Órdenes recientes
                    </div>

                    <div class="table-responsive">
                      <table class="table table-hover mb-0">
                        <thead>
                          <tr>
                            <th>Orden</th>
                            <th>Paciente</th>
                            <th>Destino</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                          </tr>
                        </thead>

                        <tbody>
                          <% recentOrders.forEach(function(o) { %>
                            <tr>
                              <td>
                                <%= o.numero_orden %>
                              </td>
                              <td>
                                <%= o.paciente %>
                              </td>
                              <td>
                                <span class="badge bg-info">
                                  <%= o.sistema_destino %>
                                </span>
                              </td>
                              <td>
                                <%= o.estado %>
                              </td>
                              <td>
                                <%= new Date(o.created_at).toLocaleString('es-CO') %>
                              </td>
                            </tr>
                            <% }) %>

                              <% if (!recentOrders.length) { %>
                                <tr>
                                  <td colspan="5" class="text-center text-muted py-4">
                                    Sin órdenes
                                  </td>
                                </tr>
                                <% } %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white fw-bold">
                      Notificaciones
                    </div>

                    <div class="card-body">
                      <% notifications.forEach(function(n) { %>
                        <div class="alert alert-info py-2">
                          <strong>
                            <%= n.titulo %>
                          </strong>
                          <br>
                          <small>
                            <%= n.mensaje %>
                          </small>
                        </div>
                        <% }) %>

                          <% if (!notifications.length) { %>
                            <p class="text-muted">Sin notificaciones</p>
                            <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </section>
        </main>
    </div>

    <%- include('../partials/scripts') %>
  </body>

</html>