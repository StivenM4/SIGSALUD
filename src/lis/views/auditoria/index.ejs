<!doctype html>
<html lang="es"><%- include('../partials/head',{title}) %>

    <body>
        <div class="app-layout"><%- include('../partials/sidebar') %>
                <main class="app-main"><%- include('../partials/navbar',{title}) %>
                        <section class="container-fluid py-4">
                            <div class="card border-0 shadow-sm rounded-4">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Usuario</th>
                                            <th>Acción</th>
                                            <th>Entidad</th>
                                            <th>Detalle</th>
                                            <th>IP</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% auditoria.forEach(a=>{ %><tr>
                                                <td>
                                                    <%= new Date(a.created_at).toLocaleString('es-CO') %>
                                                </td>
                                                <td>
                                                    <%= a.usuario_email || a.usuario_id || 'Sistema' %>
                                                </td>
                                                <td>
                                                    <%= a.accion %>
                                                </td>
                                                <td>
                                                    <%= a.entidad || '' %>
                                                </td>
                                                <td>
                                                    <%= a.detalle || '' %>
                                                </td>
                                                <td>
                                                    <%= a.ip || '' %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% if(!auditoria.length){ %>
                                                    <tr>
                                                        <td colspan="6" class="text-center text-muted py-4">No hay
                                                            auditoría registrada.</td>
                                                    </tr>
                                                    <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                </main>
        </div><%- include('../partials/scripts') %>
    </body>

</html>