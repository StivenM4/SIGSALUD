<!doctype html>
<html lang="es">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <main class="container py-5">
        <div class="card border-0 shadow-sm rounded-4 mx-auto" style="max-width:620px">
            <div class="card-body p-5 text-center">
                <h1 class="fw-bold text-danger">Acceso denegado</h1>
                <p>No tiene permisos para <strong>
                        <%= requiredSystem %>
                    </strong>.</p><a class="btn btn-primary" href="<%= authUrl %>?system=RIS">Volver</a>
            </div>
        </div>
    </main>
</body>

</html>